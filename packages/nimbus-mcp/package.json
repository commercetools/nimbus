{
  "name": "@commercetools/nimbus-mcp",
  "version": "2.10.0",
  "description": "MCP server for the Nimbus design system",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": ["dist", "data"],
  "repository": {
    "type": "git",
    "url": "https://github.com/commercetools/nimbus.git"
  },
  "bin": {
    "nimbus-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "tsx scripts/prebuild.ts",
    "build": "pnpm prebuild && tsup",
    "dev": "tsx src/index.ts",
    "mcp-inspector": "mcp-inspector tsx src/index.ts",
    "mcp-inspector:cli": "mcp-inspector --cli tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@commercetools/nimbus": "workspace:^",
    "@commercetools/nimbus-icons": "workspace:^",
    "@commercetools/nimbus-tokens": "workspace:^",
    "@modelcontextprotocol/inspector": "catalog:tooling",
    "@types/node": "catalog:utils",
    "tsup": "catalog:tooling",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling"
  }
}
