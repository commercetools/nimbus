{
  "name": "@commercetools/nimbus-icons",
  "version": "3.2.0",
  "main": "dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./meta": {
      "import": {
        "types": "./dist/esm/meta.d.ts",
        "default": "./dist/esm/meta.js"
      },
      "require": {
        "types": "./dist/cjs/meta.d.ts",
        "default": "./dist/cjs/meta.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/commercetools/nimbus.git"
  },
  "dependencies": {
    "@material-design-icons/svg": "^0.14.15",
    "@svgr/cli": "^8.1.0"
  },
  "devDependencies": {
    "@svgr/babel-plugin-add-jsx-attribute": "^8.0.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@types/node": "catalog:utils",
    "@types/react": "catalog:react",
    "react": "catalog:react",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling"
  },
  "scripts": {
    "build": "pnpm run build:icons && pnpm run build:esm && pnpm run build:cjs && pnpm run build:postbuild",
    "build:icons": "pnpm svgr --filename-case kebab --typescript --jsx-runtime automatic --out-dir src/material-icons node_modules/@material-design-icons/svg/outlined",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:postbuild": "node scripts/postbuild.mjs",
    "sync:meta": "tsx scripts/sync-meta.ts",
    "dev": "pnpm run build:esm && pnpm run build:cjs && pnpm run build:postbuild"
  }
}
