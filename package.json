{
  "name": "nimbus",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "preconstruct": {
    "packages": ["packages/tokens"]
  },
  "scripts": {
    "build": "pnpm build:tokens && pnpm run build:packages && pnpm run build:docs && pnpm run build:mcp",
    "build:packages": "pnpm -r --filter './packages/*' --filter '!@commercetools/nimbus-mcp' build",
    "build:mcp": "pnpm --filter @commercetools/nimbus-mcp build",
    "build:docs-data": "pnpm --filter docs build:docs",
    "build:docs": "pnpm --filter './apps/docs' build",
    "build:tokens": "pnpm --filter @commercetools/nimbus-tokens run build && preconstruct build",
    "changeset": "changeset",
    "openspec": "openspec",
    "changeset:version-and-format": "changeset version && prettier --write --parser json '**/package.json' && pnpm install --lockfile-only",
    "changeset:status": "changeset status --verbose",
    "extract-intl": "tsx packages/i18n/scripts/extract-messages.ts && pnpm --filter @commercetools/nimbus-i18n build",
    "generate:tokens": "pnpm --filter @commercetools/nimbus-tokens run build",
    "lint": "eslint .",
    "typecheck": "pnpm -r --filter './packages/*' --bail=false typecheck || true",
    "typecheck:strict": "pnpm -r --filter './packages/*' typecheck",
    "nimbus:init": "pnpm nimbus:reset && pnpm install && pnpm extract-intl && pnpm build && pnpm playwright:install",
    "nimbus:reset": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name 'dist' -type d -prune -exec rm -rf '{}' +",
    "playwright:install": "pnpm exec playwright install chromium",
    "start": "pnpm run start:docs & pnpm run start:storybook",
    "start:docs": "pnpm --filter './apps/docs' run dev",
    "start:storybook": "pnpm --filter @commercetools/nimbus run storybook",
    "start:mcp-inspector": "pnpm --filter @commercetools/nimbus-mcp run mcp-inspector",
    "start:mcp-inspector:cli": "pnpm --filter @commercetools/nimbus-mcp run mcp-inspector:cli",
    "test": "pnpm vitest run",
    "test:unit": "pnpm vitest run --project=unit",
    "test:storybook": "pnpm vitest run --project=storybook",
    "test:dev": "pnpm vitest run --config vitest.dev.config.ts",
    "test:storybook:dev": "pnpm vitest run --config vitest.dev.config.ts --project=storybook-dev",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "update:bundle-sizes": "node scripts/update-bundle-sizes.mjs"
  },
  "packageManager": "pnpm@10.12.3+sha512.467df2c586056165580ad6dfb54ceaad94c5a30f80893ebdec5a44c5aa73c205ae4a5bb9d5ed6bb84ea7c249ece786642bbb49d06a307df218d03da41c317417",
  "pnpm": {
    "overrides": {
      "rollup": "catalog:tooling",
      "@babel/runtime": "catalog:tooling",
      "prismjs": "^1.30.0",
      "typescript": "catalog:tooling",
      "react-aria": "catalog:react",
      "react-aria-components": "catalog:react",
      "react-stately": "catalog:react",
      "@react-aria/interactions": "catalog:react",
      "brace-expansion@<2": "^2.0.3",
      "brace-expansion@2": "~2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "mdast-util-to-hast": "^13.2.1",
      "js-yaml": "^3.14.2",
      "qs": "^6.14.2",

      "minimatch@>=3.0.0 <3.1.4": "3.1.4",
      "svgo": ">=3.3.3",
      "hono": ">=4.12.12",
      "@hono/node-server": ">=1.19.13",
      "lodash@<4.18.0": ">=4.18.0",
      "lodash-es@<4.18.0": ">=4.18.0",
      "ajv@>=8.0.0 <8.18.0": ">=8.18.0",
      "minimatch@>=10.0.0 <10.2.3": ">=10.2.3",
      "flatted": ">=3.4.2",
      "undici": ">=7.24.0",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@1": "1.10.3",
      "yaml@2": ">=2.8.3",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "happy-dom@<20.8.9": ">=20.8.9",
      "jsdom": "catalog:tooling"
    },
    "onlyBuiltDependencies": [
      "@bundled-es-modules/glob",
      "@swc/core",
      "es5-ext",
      "esbuild",
      "msw",
      "style-dictionary"
    ]
  },
  "devDependencies": {
    "@babel/core": "catalog:tooling",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@commercetools/nimbus": "workspace:^",
    "@eslint/js": "catalog:tooling",
    "@fission-ai/openspec": "catalog:tooling",
    "@preconstruct/cli": "catalog:tooling",
    "eslint": "catalog:tooling",
    "eslint-config-prettier": "catalog:tooling",
    "eslint-plugin-prettier": "catalog:tooling",
    "eslint-plugin-react-hooks": "catalog:tooling",
    "eslint-plugin-storybook": "catalog:tooling",
    "globals": "catalog:tooling",
    "playwright": "catalog:tooling",
    "prettier": "catalog:tooling",
    "tsx": "catalog:tooling",
    "typescript": "catalog:tooling",
    "typescript-eslint": "catalog:tooling",
    "vite-bundle-analyzer": "catalog:tooling",
    "vitest": "catalog:tooling"
  },
  "engines": {
    "node": ">=24.12",
    "pnpm": ">=10"
  }
}
